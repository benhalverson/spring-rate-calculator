{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "spring-rate-calculator",
	"compatibility_date": "2026-02-15",
	"observability": {
		"logs": {
			"enabled": true,
			"invocation_logs": true
		}
	},
	"main": "./src/worker.ts",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "spring-rate-sync-db",
			"database_id": "spring-rate-sync-db"
		}
	]
}
