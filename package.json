		"deploy": "pnpm build && wrangler deploy --config wrangler.jsonc --env=\"\"",
		"deploy:api": "pnpm build:api && wrangler deploy --config wrangler.jsonc --env api",
		"db:generate": "drizzle-kit generate --config drizzle.config.ts",
		"db:migrate:local": "wrangler d1 migrations apply DB --config wrangler.jsonc --env api --local",
