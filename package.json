		"db:migrations:list:local": "wrangler d1 migrations list DB --config wrangler.jsonc --env api --local",
		"db:schema:local": "wrangler d1 export DB --config wrangler.jsonc --env api --local --no-data --output /tmp/spring-rate-calculator-d1-schema.sql",
